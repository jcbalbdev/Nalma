---
const nav = {
  productos: [
    { href: '#bebe', label: 'Para bebé' },
    { href: '#mama', label: 'Para mamá' },
    { href: '#todo', label: 'Todo' },
  ],
  empresa: [
    { href: '#nosotros',  label: 'Nosotros' },
    { href: '#valores',   label: 'Nuestros valores' },
    { href: '#contacto',  label: 'Contacto' },
  ],
  ayuda: [
    { href: '#envios',       label: 'Envíos' },
    { href: '#devoluciones', label: 'Devoluciones' },
    { href: '#preguntas',    label: 'Preguntas frecuentes' },
  ],
};
---

<footer class="footer">
  <div class="container footer__inner">

    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Nalma — Inicio">NALMA</a>
      <p class="footer__tagline">Cuidado que calma</p>
      <p class="footer__desc">
        Para ti, para tu bebé, para todo momento.<br />
        Formulados para acompañar.
      </p>
      <p class="footer__location">Lima, Perú · nalma.pe</p>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      {Object.entries(nav).map(([key, links]) => (
        <div class="footer__nav-group">
          <h3 class="footer__nav-title">{key.charAt(0).toUpperCase() + key.slice(1)}</h3>
          <ul class="footer__nav-list">
            {links.map(l => (
              <li><a href={l.href} class="footer__nav-link">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

  </div>

  <div class="container footer__bottom">
    <p class="footer__copy">© 2026 Nalma. Todos los derechos reservados.</p>

    <div class="footer__social">
      <a href="#" class="footer__social-link" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <a href="#" class="footer__social-link" aria-label="TikTok">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--oliva);
    color: var(--crema);
    padding-top: var(--sp-16);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-16);
    padding-bottom: var(--sp-12);
  }

  .footer__logo {
    font-family: var(--font-logo);
    font-weight: 900;
    font-size: var(--text-2xl);
    color: var(--crema);
    display: block;
    margin-bottom: var(--sp-2);
    letter-spacing: 0.02em;
  }

  .footer__tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-lg);
    opacity: 0.65;
    margin-bottom: var(--sp-4);
  }

  .footer__desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    opacity: 0.65;
    margin-bottom: var(--sp-4);
  }

  .footer__location {
    font-size: var(--text-xs);
    opacity: 0.4;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .footer__nav-title {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.4;
    margin-bottom: var(--sp-4);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    opacity: 0.75;
    transition: opacity var(--ease);
  }
  .footer__nav-link:hover { opacity: 1; }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-6);
    padding-bottom: var(--sp-6);
    border-top: 1px solid rgba(245, 240, 230, 0.12);
  }

  .footer__copy {
    font-size: var(--text-xs);
    opacity: 0.4;
  }

  .footer__social {
    display: flex;
    gap: var(--sp-4);
  }

  .footer__social-link {
    color: var(--crema);
    opacity: 0.55;
    transition: opacity var(--ease);
  }
  .footer__social-link:hover { opacity: 1; }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--sp-10);
    }
    .footer__nav { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .footer__nav { grid-template-columns: 1fr; }
  }
</style>
