---
const badges = [
  {
    title: 'Dermatológicamente probado',
    desc:  'Testado por dermatólogos para garantizar su seguridad.',
    icon:  'drop',
  },
  {
    title: 'Hipoalergénico',
    desc:  'Fórmula diseñada para minimizar reacciones alérgicas.',
    icon:  'leaf',
  },
  {
    title: 'Apto durante embarazo y lactancia',
    desc:  'Ingredientes seguros en las etapas más importantes.',
    icon:  'pregnant',
  },
  {
    title: 'Extra cuidado / Favoritos',
    desc:  'Los más amados por nuestra comunidad Nalma.',
    icon:  'star',
  },
];
---

<section class="trust section">
  <div class="container trust__grid">
    {badges.map(b => (
      <div class="trust__item">
        <div class="trust__icon">
          {b.icon === 'drop' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6 10 4 14 4 17a8 8 0 0016 0c0-3-2-7-8-15z"/>
              <path d="M8 18a4 4 0 004 2.5"/>
            </svg>
          )}
          {b.icon === 'leaf' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 20A7 7 0 014 13c0-4 4-9 8-11 4 2 8 7 8 11a7 7 0 01-7 7h-2z"/>
              <path d="M7 13l5-5"/>
            </svg>
          )}
          {b.icon === 'pregnant' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="5.5" r="2.5"/>
              <path d="M8.5 10.5c0 0 .5 2 3.5 2s3.5-2 3.5-2V15c0 2-1 3.5-3.5 4.5C9.5 18.5 8.5 17 8.5 15v-4.5z"/>
              <path d="M10 17l1.5 1.5L15 15"/>
            </svg>
          )}
          {b.icon === 'star' && (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6L12 2z"/>
              <line x1="12" y1="8" x2="12" y2="14"/>
              <line x1="9"  y1="11" x2="15" y2="11"/>
            </svg>
          )}
        </div>
        <h3 class="trust__title">{b.title}</h3>
        <p class="trust__desc">{b.desc}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .trust { background: var(--crema); }

  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
  }

  .trust__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-4);
    padding: var(--sp-8) var(--sp-5);
    border: 1.5px solid var(--crema-oscura);
    border-radius: var(--radius-xl);
    transition: border-color var(--ease), transform var(--ease);
  }
  .trust__item:hover {
    border-color: var(--verde);
    transform: translateY(-5px);
  }

  .trust__icon {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--oliva-medio);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--oliva);
    flex-shrink: 0;
  }

  .trust__title {
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--oliva);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  .trust__desc {
    font-size: var(--text-xs);
    color: var(--gris-medio);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .trust__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .trust__grid { grid-template-columns: 1fr; }
  }
</style>
