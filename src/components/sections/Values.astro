---
const values = [
  {
    num: '01',
    title: 'La ciencia del balance',
    desc: 'Cada producto está formulado con precisión para encontrar el equilibrio perfecto entre efectividad y suavidad para piel sensible.',
  },
  {
    num: '02',
    title: 'Abrazando el caos',
    desc: 'Sabemos que la maternidad es impredecible. Estamos aquí para hacerla más llevadera, sin pretender que todo es perfecto.',
  },
  {
    num: '03',
    title: 'En las buenas y en las peores',
    desc: 'No solo para los días perfectos. Nalma te acompaña en cada momento, especialmente en los más difíciles.',
  },
];
---

<section class="values section" id="valores">
  <div class="container">

    <div class="values__header">
      <span class="values__eyebrow">Nuestro ADN</span>
      <h2 class="values__title">Lo que somos</h2>
    </div>

    <div class="values__grid">
      {values.map(v => (
        <div class="values__card">
          <span class="values__num">{v.num}</span>
          <h3 class="values__card-title">{v.title}</h3>
          <p class="values__card-desc">{v.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .values { background: var(--crema-oscura); }

  .values__header {
    margin-bottom: var(--sp-12);
  }

  .values__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oliva-medio);
    margin-bottom: var(--sp-2);
  }

  .values__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-4xl);
    color: var(--oliva);
  }

  .values__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
  }

  .values__card {
    padding: var(--sp-8);
    background: var(--crema);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    transition: transform var(--ease);
  }
  .values__card:hover { transform: translateY(-5px); }

  .values__num {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--oliva);
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .values__card-title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-xl);
    color: var(--oliva);
    line-height: 1.3;
  }

  .values__card-desc {
    font-size: var(--text-sm);
    color: var(--gris-medio);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .values__grid { grid-template-columns: 1fr; gap: var(--sp-4); }
    .values__title { font-size: var(--text-3xl); }
  }
</style>
