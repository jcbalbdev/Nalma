---
import ProductCard from '../ui/ProductCard.astro';
import { products } from '../../data/products';

// Para agregar un producto aquí: ve a src/data/products.ts y ponle featured: true
const featured = products.filter(p => p.featured);
---

<section class="products section" id="todo">
  <div class="container">

    <div class="products__header">
      <div>
        <span class="products__eyebrow">Nuestros productos</span>
        <h2 class="products__title">
          Los <em>favoritos</em><br />de mamá
        </h2>
      </div>
      <a href="/productos" class="products__arrow" aria-label="Ver todos los productos">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
          <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="1.5"/>
          <path d="M20 16l8 8-8 8" stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="products__grid">
      {featured.map(product => (
        <ProductCard product={product} />
      ))}
    </div>

    <div class="products__all">
      <a href="/productos" class="products__all-link">
        Ver todos los productos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .products { background: var(--crema); }

  .products__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--sp-10);
  }

  .products__eyebrow {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oliva-medio);
    margin-bottom: var(--sp-2);
  }

  .products__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: var(--text-4xl);
    color: var(--oliva);
    line-height: 1.15;
  }

  .products__title em { font-style: italic; }

  .products__arrow {
    color: var(--oliva);
    flex-shrink: 0;
    transition: transform var(--ease), color var(--ease);
  }
  .products__arrow:hover {
    transform: translateX(5px);
    color: var(--verde);
  }

  .products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-6);
  }

  .products__all {
    display: flex;
    justify-content: center;
    margin-top: var(--sp-10);
  }

  .products__all-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-weight: 500;
    color: var(--oliva);
    border-bottom: 1.5px solid var(--oliva);
    padding-bottom: var(--sp-1);
    transition: color var(--ease), border-color var(--ease);
  }
  .products__all-link:hover {
    color: var(--verde);
    border-color: var(--verde);
  }

  @media (max-width: 580px) {
    .products__grid { grid-template-columns: 1fr; }
    .products__title { font-size: var(--text-3xl); }
  }
</style>
