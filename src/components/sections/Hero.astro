---
import Button from '../ui/Button.astro';
---

<section class="hero">
  <div class="container hero__inner">

    <div class="hero__content">
      <p class="hero__eyebrow">Cuidado que calma</p>

      <h1 class="hero__title">
        Para los días<br />
        <em>perfectos</em> y los<br />
        que no lo son.
      </h1>

      <p class="hero__subtitle">
        Productos que te acompañan a ti y tu bebé<br />
        en momentos que llenan tu día.
      </p>

      <Button href="#todo" variant="outline" size="lg">
        Conócenos
      </Button>
    </div>

    <div class="hero__visual">
      <!-- 📸 Cuando tengas la foto real, reemplaza el div.hero__photo-placeholder con:
           <img src="/hero-photo.jpg" alt="Mamá y bebé" class="hero__photo" /> -->
      <div class="hero__photo-placeholder" aria-hidden="true"></div>
      <div class="hero__blob" aria-hidden="true"></div>
    </div>

  </div>

  <div class="hero__tagline-strip">
    <span>Para bebé</span>
    <span aria-hidden="true">·</span>
    <span>Para mamá</span>
    <span aria-hidden="true">·</span>
    <span>En las buenas y en las peores</span>
    <span aria-hidden="true">·</span>
    <span>Cuidado que calma</span>
    <span aria-hidden="true">·</span>
    <span>Nalma.pe</span>
    <span aria-hidden="true">·</span>
    <span>Lima, Perú</span>
    <span aria-hidden="true">·</span>
  </div>
</section>

<style>
  .hero {
    background: var(--crema);
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .hero__inner {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    align-items: center;
    padding-top: var(--sp-20);
    padding-bottom: var(--sp-20);
  }

  /* ── Content ── */
  .hero__eyebrow {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--oliva-medio);
    margin-bottom: var(--sp-4);
  }

  .hero__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(2.4rem, 4.5vw, 4.5rem);
    color: var(--negro);
    line-height: 1.12;
    margin-bottom: var(--sp-6);
  }

  .hero__title em {
    font-style: italic;
    color: var(--oliva);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--gris-medio);
    line-height: 1.65;
    margin-bottom: var(--sp-10);
  }

  /* ── Visual ── */
  .hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 520px;
  }

  /* Foto circular — reemplaza este div con <img class="hero__photo" /> cuando tengas la imagen */
  .hero__photo-placeholder,
  .hero__photo {
    position: relative;
    z-index: 1;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    object-fit: cover;
    overflow: hidden;
    background: radial-gradient(
      circle at 55% 40%,
      #d4c4a8 0%,
      #b8a88a 40%,
      #9a8870 70%,
      #7a6e58 100%
    );
    box-shadow: 0 24px 64px rgba(105, 103, 83, 0.2);
  }

  .hero__blob {
    position: absolute;
    bottom: 40px;
    left: 30px;
    z-index: 2;
    width: 160px;
    height: 160px;
    border-radius: 62% 38% 52% 48% / 44% 56% 44% 56%;
    background: radial-gradient(
      circle at 40% 35%,
      #FAFBA8 0%,
      var(--amarillo) 55%,
      transparent 80%
    );
    opacity: 0.85;
  }

  /* ── Tagline strip ── */
  .hero__tagline-strip {
    display: flex;
    align-items: center;
    gap: var(--sp-6);
    padding: var(--sp-4) var(--sp-8);
    background: var(--crema-oscura);
    border-top: 1px solid var(--crema-oscura);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--oliva-medio);
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }

  .hero__tagline-strip::-webkit-scrollbar { display: none; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: var(--sp-16);
      padding-bottom: var(--sp-12);
      gap: var(--sp-8);
    }
    .hero__visual {
      order: -1;
      height: 320px;
    }
    .hero__photo-placeholder,
    .hero__photo {
      width: 280px;
      height: 280px;
    }
    .hero__blob {
      width: 110px;
      height: 110px;
      bottom: 20px;
      left: calc(50% - 160px);
    }
    .hero__subtitle br { display: none; }
  }
</style>
