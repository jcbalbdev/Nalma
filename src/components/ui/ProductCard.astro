---
import Badge from './Badge.astro';
import type { Product } from '../../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const bgColors = {
  bebe: 'var(--amarillo-claro)',
  mama: 'var(--rosa-claro)',
};

const blobColors = {
  bebe: 'radial-gradient(circle at 42% 38%, #FAFBA8 0%, var(--amarillo) 58%, transparent 80%)',
  mama: 'radial-gradient(circle at 42% 38%, #FDE8E4 0%, var(--rosa) 58%, transparent 80%)',
};
---

<article class="card">
  <div class="card__image" style={`background:${bgColors[product.category]};`}>
    {product.isNew && <span class="card__new">Nuevo</span>}

    <div class="card__blob" style={`background:${blobColors[product.category]};`} aria-hidden="true" />

    <div class="card__image-footer">
      <span class="card__brand">NALMA</span>
      <span class="card__num">{product.num}</span>
    </div>
  </div>

  <div class="card__body">
    <div class="card__top">
      <h3 class="card__name">{product.name}</h3>
      <Badge category={product.category} subcategory={product.subcategory} />
    </div>
    <p class="card__desc">{product.description}</p>
    <div class="card__foot">
      <span class="card__size">{product.size}</span>
      <span class="card__price">S/{product.price}</span>
    </div>
  </div>
</article>

<style>
  .card {
    background: var(--blanco);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--ease), box-shadow var(--ease);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.09);
  }

  /* Image area */
  .card__image {
    position: relative;
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card__new {
    position: absolute;
    top: var(--sp-3);
    left: var(--sp-3);
    background: var(--oliva);
    color: var(--crema);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--sp-1) var(--sp-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .card__blob {
    width: 56%;
    height: 64%;
    border-radius: 44% 56% 40% 60% / 68% 32% 68% 32%;
  }

  .card__image-footer {
    position: absolute;
    bottom: var(--sp-4);
    left: var(--sp-4);
    right: var(--sp-4);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .card__brand {
    font-family: var(--font-logo);
    font-weight: 900;
    font-size: var(--text-2xl);
    color: var(--oliva);
    line-height: 1;
  }

  .card__num {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--oliva);
    opacity: 0.45;
    letter-spacing: 0.05em;
  }

  /* Body */
  .card__body {
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    flex: 1;
  }

  .card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-2);
  }

  .card__name {
    font-weight: 500;
    font-size: var(--text-lg);
    color: var(--negro);
    line-height: 1.3;
  }

  .card__desc {
    font-size: var(--text-sm);
    color: var(--gris-medio);
    line-height: 1.5;
  }

  .card__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: var(--sp-3);
  }

  .card__size {
    font-size: var(--text-sm);
    color: var(--gris-medio);
  }

  .card__price {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--oliva);
    background: var(--crema);
    padding: var(--sp-1) var(--sp-4);
    border-radius: var(--radius-full);
  }
</style>
