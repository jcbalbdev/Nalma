---
// ⚠️ Debe coincidir con WA_NUMBER en ProductModal.astro y Layout.astro
const WA_NUMBER = '51999999999';
---

<!-- Overlay -->
<div class="cd-overlay" id="cd-overlay" aria-hidden="true"></div>

<!-- Drawer -->
<aside
  class="cd"
  id="cd"
  role="dialog"
  aria-modal="true"
  aria-label="Tu carrito"
  aria-hidden="true"
  data-wa={WA_NUMBER}
>
  <div class="cd__head">
    <div>
      <h2 class="cd__title">Tu carrito</h2>
      <p class="cd__count" id="cd-count">0 productos</p>
    </div>
    <button class="cd__close" id="cd-close" aria-label="Cerrar carrito">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <line x1="5" y1="5" x2="19" y2="19"/>
        <line x1="19" y1="5" x2="5" y2="19"/>
      </svg>
    </button>
  </div>

  <!-- Lista de productos -->
  <div class="cd__body" id="cd-body">
    <!-- Se renderiza dinámicamente con JS -->
  </div>

  <!-- Footer -->
  <div class="cd__foot" id="cd-foot">
    <!-- Se renderiza dinámicamente con JS -->
  </div>
</aside>

<script is:inline>
  var cdOverlay = document.getElementById('cd-overlay');
  var cdDrawer  = document.getElementById('cd');
  var cdClose   = document.getElementById('cd-close');
  var cdBody    = document.getElementById('cd-body');
  var cdFoot    = document.getElementById('cd-foot');
  var cdCount   = document.getElementById('cd-count');
  var CD_WA = cdDrawer ? cdDrawer.dataset.wa : '';

  function openCart() {
    renderCart(); // siempre re-renderiza al abrir
    cdDrawer.setAttribute('aria-hidden', 'false');
    cdDrawer.classList.add('is-open');
    cdOverlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    cdClose && cdClose.focus();
  }

  function closeCart() {
    cdDrawer.setAttribute('aria-hidden', 'true');
    cdDrawer.classList.remove('is-open');
    cdOverlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }
  window.closeCart   = closeCart;  // necesario para onclick en innerHTML
  window.openCart    = openCart;   // llamado directamente desde Header

  function fmt(n) {
    return 'S/' + (Number.isInteger(n) ? n : n.toFixed(2));
  }

  var catLabel = { bebe: 'Para bebé', mama: 'Para mamá', todo: 'Para todo' };
  var thumbBg = {
    bebe: '#ECE17A',
    mama: '#F2C4C4',
    todo: '#B8D4B0',
  };

  function buildWaCartMessage(items, total) {
    var DR = window.NALMA_CART ? window.NALMA_CART._DR : 0.10;
    var msg = 'Hola! Quisiera hacer el siguiente pedido:\n\n';
    msg += '🛍️ *Mi pedido:*\n\n';
    items.forEach(function(item, i) {
      msg += (i + 1) + '. *' + item.name + '* (' + item.size + ') × ' + item.qty + ' — ' + fmt(item.total) + '\n';
      if (item.hasDiscount) {
        msg += '   ✨ Descuento ' + Math.round(DR * 100) + '% aplicado (antes ' + fmt(item.unitPrice * item.qty) + ')\n';
      }
    });
    msg += '\n💵 *Total: ' + fmt(total) + '*\n\n';
    msg += '¿Pueden confirmar disponibilidad y coordinar el envío? ¡Gracias!';
    return msg;
  }

  function renderCart() {
    var cart  = window.NALMA_CART;
    var items = cart ? cart.items : [];
    var total = cart ? cart.grandTotal() : 0;
    var count = cart ? cart.count() : 0;

    // Update counter
    if (cdCount) {
      cdCount.textContent = count === 0
        ? 'Vacío'
        : count + ' producto' + (count > 1 ? 's' : '');
    }

    if (items.length === 0) {
      cdBody.innerHTML =
        '<div class="cd__empty">' +
          '<div class="cd__empty-icon">🛍️</div>' +
          '<p class="cd__empty-title">Tu carrito está vacío</p>' +
          '<p class="cd__empty-sub">Explora los productos y agrega los que más te gusten.</p>' +
          '<a href="#todo" class="cd__empty-cta" onclick="closeCart()">Ver productos</a>' +
        '</div>';
      cdFoot.innerHTML = '';
      return;
    }

    // Render items
    var blobSvg =
      '<svg width="40" height="52" viewBox="0 0 60 76" fill="none" aria-hidden="true">' +
        '<ellipse cx="30" cy="44" rx="22" ry="30" fill="rgba(255,255,255,0.38)"/>' +
        '<ellipse cx="30" cy="18" rx="10" ry="13" fill="rgba(255,255,255,0.25)"/>' +
      '</svg>';

    var html = '<ul class="cd__list">';
    items.forEach(function(item) {
      var bg   = thumbBg[item.category] || '#E8E4D8';
      var meta = (item.subcategory || catLabel[item.category] || '') + ' · ' + item.size;

      html +=
        '<li class="cd__item" data-id="' + item.id + '">' +
          '<div class="cd__thumb" style="background:' + bg + '" aria-hidden="true">' + blobSvg + '</div>' +
          '<div class="cd__item-body">' +
            '<button class="cd__item-remove" data-id="' + item.id + '" aria-label="Eliminar ' + item.name + '">×</button>' +
            '<p class="cd__item-name">' + item.name + '</p>' +
            '<p class="cd__item-meta">' + meta + '</p>' +
            '<p class="cd__item-price' + (item.hasDiscount ? ' has-discount' : '') + '">' + fmt(item.total) + '</p>' +
            (item.hasDiscount ? '<p class="cd__item-saved">Ahorras ' + fmt(item.saved) + '</p>' : '') +
            '<div class="cd__qty">' +
              '<button class="cd__qty-btn" data-action="minus" data-id="' + item.id + '" aria-label="Restar">−</button>' +
              '<span class="cd__qty-val">' + item.qty + '</span>' +
              '<button class="cd__qty-btn cd__qty-plus" data-action="plus" data-id="' + item.id + '" aria-label="Sumar">+</button>' +
            '</div>' +
          '</div>' +
        '</li>';
    });
    html += '</ul>';
    cdBody.innerHTML = html;

    // Render footer
    var waMsg  = buildWaCartMessage(items, total);
    var waHref = 'https://wa.me/' + CD_WA + '?text=' + encodeURIComponent(waMsg);

    cdFoot.innerHTML =
      '<div class="cd__total-row">' +
        '<span class="cd__total-label">Total</span>' +
        '<span class="cd__total-price">' + fmt(total) + '</span>' +
      '</div>' +
      '<a class="cd__cta" href="' + waHref + '" target="_blank" rel="noopener noreferrer">' +
        '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>' +
        'Pedir todo por WhatsApp' +
      '</a>' +
      '<p class="cd__note">Tu pedido se abrirá en WhatsApp listo para enviar.</p>';

    // Item controls
    cdBody.querySelectorAll('.cd__qty-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id     = Number(btn.dataset.id);
        var action = btn.dataset.action;
        var item   = window.NALMA_CART.items.find(function(i) { return i.id === id; });
        if (!item) return;
        window.NALMA_CART.updateQty(id, action === 'plus' ? item.qty + 1 : item.qty - 1);
      });
    });

    cdBody.querySelectorAll('.cd__item-remove').forEach(function(btn) {
      btn.addEventListener('click', function() {
        window.NALMA_CART.remove(Number(btn.dataset.id));
      });
    });
  }

  // Events
  window.addEventListener('nalma:cart:changed', renderCart);
  window.addEventListener('nalma:cart:open', openCart);

  cdClose   && cdClose.addEventListener('click', closeCart);
  cdOverlay && cdOverlay.addEventListener('click', closeCart);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && cdDrawer.classList.contains('is-open')) closeCart();
  });

  // Initial render
  renderCart();
</script>

<style is:global>
  /* ── Overlay ── */
  .cd-overlay {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: rgba(28, 28, 26, 0.5);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .cd-overlay.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Drawer shell ── */
  .cd {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 160;
    width: 440px;
    max-width: 100vw;
    background: var(--crema);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -12px 0 56px rgba(60, 58, 40, 0.14);
  }
  .cd.is-open { transform: translateX(0); }

  /* ── Head ── */
  .cd__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    background: var(--crema);
    border-bottom: 1px solid var(--crema-oscura);
    flex-shrink: 0;
  }
  .cd__title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--negro);
    letter-spacing: -0.01em;
  }
  .cd__count {
    font-size: 0.8rem;
    color: var(--gris-medio);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }
  .cd__close {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--oliva);
    transition: background var(--ease);
    flex-shrink: 0;
  }
  .cd__close:hover { background: var(--crema-oscura); }

  /* ── Body (scrollable) ── */
  .cd__body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 16px;
  }
  .cd__body::-webkit-scrollbar { width: 4px; }
  .cd__body::-webkit-scrollbar-track { background: transparent; }
  .cd__body::-webkit-scrollbar-thumb { background: var(--crema-oscura); border-radius: 4px; }

  /* ── Empty state ── */
  .cd__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 32px;
    text-align: center;
    gap: 12px;
  }
  .cd__empty-icon { font-size: 3rem; line-height: 1; }
  .cd__empty-title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--negro);
    margin-top: 4px;
  }
  .cd__empty-sub {
    font-size: 0.875rem;
    color: var(--gris-medio);
    line-height: 1.6;
    max-width: 220px;
  }
  .cd__empty-cta {
    margin-top: 8px;
    padding: 10px 24px;
    border: 1.5px solid var(--oliva);
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--oliva);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background var(--ease), color var(--ease);
    text-decoration: none;
  }
  .cd__empty-cta:hover { background: var(--oliva); color: var(--crema); }

  /* ── Item list ── */
  .cd__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .cd__item {
    display: flex;
    align-items: stretch;
    gap: 14px;
    padding: 14px;
    background: #fff;
    border: 1px solid var(--crema-oscura);
    border-radius: 16px;
    position: relative;
    transition: box-shadow var(--ease);
  }
  .cd__item:hover { box-shadow: 0 2px 14px rgba(60,58,40,0.08); }

  /* thumbnail */
  .cd__thumb {
    width: 76px;
    min-height: 76px;
    border-radius: 10px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* content column */
  .cd__item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    padding-right: 20px;
  }
  .cd__item-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--negro);
    line-height: 1.3;
    margin-bottom: 2px;
  }
  .cd__item-meta {
    font-size: 0.75rem;
    color: var(--gris-medio);
    margin-bottom: 6px;
  }
  .cd__item-price {
    font-size: 1rem;
    font-weight: 700;
    color: var(--negro);
    margin-bottom: 4px;
  }
  .cd__item-price.has-discount { color: var(--negro); }
  .cd__item-saved {
    font-size: 0.7rem;
    color: #1a9e52;
    font-weight: 600;
    background: #e8f7ee;
    border-radius: 99px;
    padding: 2px 7px;
    align-self: flex-start;
    margin-bottom: 6px;
  }

  /* qty stepper */
  .cd__qty {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 8px;
  }
  .cd__qty-btn {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--crema-oscura);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--oliva);
    font-size: 1.1rem;
    cursor: pointer;
    transition: border-color var(--ease), background var(--ease);
    line-height: 1;
    flex-shrink: 0;
  }
  .cd__qty-btn:hover { border-color: var(--oliva); }
  .cd__qty-plus {
    background: var(--oliva);
    color: var(--crema);
    border-color: var(--oliva);
  }
  .cd__qty-plus:hover { background: #4a4a30; border-color: #4a4a30; }
  .cd__qty-val {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--negro);
    min-width: 18px;
    text-align: center;
  }

  /* remove button */
  .cd__item-remove {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    font-size: 0.95rem;
    color: var(--gris-medio);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--ease), color var(--ease);
    line-height: 1;
    cursor: pointer;
  }
  .cd__item-remove:hover { background: #fdecea; color: #c0392b; }

  /* ── Footer ── */
  .cd__foot {
    border-top: 1px solid var(--crema-oscura);
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
    background: var(--crema);
  }

  .cd__total-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 4px;
  }
  .cd__total-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gris-medio);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cd__total-price {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--negro);
    letter-spacing: -0.01em;
  }

  .cd__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 14px 24px;
    border-radius: 99px;
    transition: background var(--ease), transform var(--ease), box-shadow var(--ease);
    text-align: center;
    text-decoration: none;
    letter-spacing: 0.01em;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.3);
  }
  .cd__cta:hover {
    background: #1ebe5d;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.38);
  }

  .cd__note {
    font-size: 0.74rem;
    color: var(--gris-medio);
    text-align: center;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .cd { width: 100vw; }
    .cd__head,
    .cd__foot { padding-left: 20px; padding-right: 20px; }
    .cd__item { padding-left: 20px; padding-right: 20px; }
  }
</style>
