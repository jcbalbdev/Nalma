---
const navLinks = [
  { href: '#bebe',     label: 'Para bebé' },
  { href: '#mama',     label: 'Para mamá' },
  { href: '#todo',     label: 'Todo' },
  { href: '#nosotros', label: 'Nosotros' },
];
---

<header class="header">
  <div class="container header__inner">

    <a href="/" class="header__logo" aria-label="Nalma — Inicio">
      NALMA
    </a>

    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="header__list">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="header__link">{link.href === '#todo' ? <strong>{link.label}</strong> : link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__actions">
      <!-- Lupa — navega a la sección de productos -->
      <a href="#todo" class="header__icon-btn" aria-label="Ver productos">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </a>

      <!-- Carrito -->
      <button class="header__icon-btn header__cart-btn" id="cart-btn" aria-label="Ver carrito">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="header__cart-badge" id="cart-badge" aria-live="polite" hidden>0</span>
      </button>

      <!-- Hamburguesa (mobile) -->
      <button class="header__menu-btn" aria-label="Abrir menú" aria-expanded="false" id="menu-btn">
        <svg class="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <line x1="4" y1="6"  x2="20" y2="6"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="18" x2="20" y2="18"/>
        </svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <line x1="5" y1="5" x2="19" y2="19"/>
          <line x1="19" y1="5" x2="5" y2="19"/>
        </svg>
      </button>
    </div>

  </div>

  <div class="header__mobile-nav" id="mobile-nav" aria-hidden="true">
    <ul class="header__mobile-list">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="header__mobile-link">{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 240, 230, 0.92);
    border-bottom: 1px solid var(--crema-oscura);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-8);
    padding-top: var(--sp-4);
    padding-bottom: var(--sp-4);
  }

  .header__logo {
    font-family: var(--font-logo);
    font-weight: 900;
    font-size: var(--text-2xl);
    color: var(--oliva);
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .header__nav { flex: 1; }

  .header__list {
    display: flex;
    gap: var(--sp-6);
  }

  .header__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oliva);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-bottom: var(--sp-1);
    border-bottom: 2px solid transparent;
    transition: border-color var(--ease), color var(--ease);
  }

  .header__link:hover {
    color: var(--negro);
    border-bottom-color: var(--oliva);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-1);
    flex-shrink: 0;
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    color: var(--oliva);
    transition: background var(--ease);
    text-decoration: none;
  }

  .header__icon-btn:hover { background: var(--crema-oscura); }

  /* Cart badge */
  .header__cart-badge {
    position: absolute;
    top: 5px;
    right: 5px;
    min-width: 18px;
    height: 18px;
    border-radius: var(--radius-full);
    background: var(--oliva);
    color: var(--crema);
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid var(--crema);
    line-height: 1;
  }

  @keyframes cart-pop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.4); }
    100% { transform: scale(1); }
  }

  .header__cart-badge.popping { animation: cart-pop 0.3s ease; }

  /* Hamburger */
  .header__menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    color: var(--oliva);
    transition: background var(--ease);
  }

  .header__menu-btn:hover { background: var(--crema-oscura); }

  .icon-close { display: none; }
  .header__menu-btn.is-open .icon-open  { display: none; }
  .header__menu-btn.is-open .icon-close { display: block; }

  /* Mobile nav dropdown */
  .header__mobile-nav {
    display: none;
    flex-direction: column;
    background: rgba(245, 240, 230, 0.98);
    border-top: 1px solid var(--crema-oscura);
    padding: var(--sp-4) 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .header__mobile-nav.is-open {
    display: flex;
    max-height: 400px;
  }

  .header__mobile-list { display: flex; flex-direction: column; }

  .header__mobile-link {
    display: block;
    padding: var(--sp-4) var(--sp-8);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--oliva);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--crema-oscura);
    transition: background var(--ease), color var(--ease);
  }

  .header__mobile-link:hover { background: var(--crema-oscura); }

  @media (max-width: 768px) {
    .header__nav      { display: none; }
    .header__actions  { margin-left: auto; }
    .header__menu-btn { display: flex; }
  }
</style>

<script is:inline>
  // ── Mobile menu ──
  var menuBtn = document.getElementById('menu-btn');
  var mobileNav = document.getElementById('mobile-nav');

  menuBtn && menuBtn.addEventListener('click', function() {
    var isOpen = menuBtn.classList.toggle('is-open');
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    mobileNav && mobileNav.classList.toggle('is-open', isOpen);
    mobileNav && mobileNav.setAttribute('aria-hidden', String(!isOpen));
  });

  mobileNav && mobileNav.querySelectorAll('.header__mobile-link').forEach(function(link) {
    link.addEventListener('click', function() {
      menuBtn && menuBtn.classList.remove('is-open');
      menuBtn && menuBtn.setAttribute('aria-expanded', 'false');
      mobileNav.classList.remove('is-open');
      mobileNav.setAttribute('aria-hidden', 'true');
    });
  });

  // ── Cart badge ──
  var cartBtn   = document.getElementById('cart-btn');
  var cartBadge = document.getElementById('cart-badge');

  function updateCartBadge() {
    var count = window.NALMA_CART ? window.NALMA_CART.count() : 0;
    if (cartBadge) {
      cartBadge.textContent = String(count);
      cartBadge.hidden = count === 0;
      if (count > 0) {
        cartBadge.classList.remove('popping');
        void cartBadge.offsetWidth; // reflow for animation reset
        cartBadge.classList.add('popping');
      }
    }
  }

  window.addEventListener('nalma:cart:changed', updateCartBadge);

  cartBtn && cartBtn.addEventListener('click', function() {
    if (typeof window.openCart === 'function') {
      window.openCart();
    } else {
      window.dispatchEvent(new CustomEvent('nalma:cart:open'));
    }
  });
</script>
